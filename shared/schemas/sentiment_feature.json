      "type": "integer"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "data_version": {
      "type": "string"
    },
    "direction": {
      "enum": ["YES", "NO", "NEUTRAL", "UNKNOWN"],
      "type": "string"
    },
    "evidence_id": {
      "type": "string"
    },
    "evidence_count": {
      "minimum": 1,
      "type": "integer"
    },
    "evidence_ids_hash": {
      "type": "string"
    },
    "feature_id": {
      "type": "string"
    },
    "feature_timestamp_ms": {
      "type": "integer"
    },
    "feature_version": {
      "type": "string"
    },
    "market_id": {
      "type": "string"
    },
    "lookback_ms": {
      "exclusiveMinimum": 0,
      "type": "integer"
    },
