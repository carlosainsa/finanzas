APP_ENV=production
EXECUTION_MODE=dry_run

REDIS_URL=redis://redis:6379
DATABASE_URL=postgres://finanzas:change-me@postgres:5432/finanzas

OPERATOR_API_URL=https://operator.example.com
PUBLIC_OPERATOR_URL=https://operator.example.com
OPERATOR_API_HOST=127.0.0.1
OPERATOR_API_PORT=18000
OPERATOR_READ_TOKEN=replace-with-read-token
OPERATOR_CONTROL_TOKEN=replace-with-control-token

POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
DISABLE_MARKET_WS=false
GO_NO_GO_PROFILE=pre_live

MARKET_ASSET_IDS=
USER_MARKET_IDS=

ENABLE_NIM_ADVISORY=false
NVIDIA_NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=deepseek-ai/deepseek-v3.2
NIM_TIMEOUT_SECONDS=30
NIM_MAX_EVIDENCE_PER_RUN=25
NIM_MAX_REQUESTS_PER_RUN=25
NIM_MAX_TOKENS_PER_RUN=0
NIM_MAX_LATENCY_MS_PER_RUN=0
NIM_MAX_COST_PER_RUN=0
NIM_FAIL_ON_BUDGET_EXCEEDED=false
NIM_INPUT_COST_PER_MILLION_TOKENS=0
NIM_OUTPUT_COST_PER_MILLION_TOKENS=0
NIM_COST_CURRENCY=USD

MAX_ORDER_SIZE=10
MIN_CONFIDENCE=0.55
SIGNAL_MAX_AGE_MS=5000
MAX_MARKET_EXPOSURE=100
MAX_DAILY_LOSS=50
ORDER_RECONCILIATION_TIMEOUT_MS=10000
CANCEL_CONFIRMATION_TIMEOUT_MS=10000

# Required only for EXECUTION_MODE=live.
PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
