APP_ENV=production
EXECUTION_MODE=dry_run

REDIS_URL=redis://redis:6379
DATABASE_URL=postgres://finanzas:change-me@postgres:5432/finanzas

OPERATOR_API_URL=https://operator.example.com
OPERATOR_READ_TOKEN=replace-with-read-token
OPERATOR_CONTROL_TOKEN=replace-with-control-token

POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
DISABLE_MARKET_WS=false

MARKET_ASSET_IDS=
USER_MARKET_IDS=

MAX_ORDER_SIZE=10
MIN_CONFIDENCE=0.55
SIGNAL_MAX_AGE_MS=5000
MAX_MARKET_EXPOSURE=100
MAX_DAILY_LOSS=50
ORDER_RECONCILIATION_TIMEOUT_MS=10000
CANCEL_CONFIRMATION_TIMEOUT_MS=10000

# Required only for EXECUTION_MODE=live.
PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
