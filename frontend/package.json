{
  "name": "polymarket-operator-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "generate:types": "PYTHONPATH=../python-service python3 ../scripts/export_openapi.py src/generated/openapi.json && openapi-typescript src/generated/openapi.json -o src/generated/openapi.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "lucide-react": "latest",
    "openapi-fetch": "^0.17.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "latest",
    "openapi-typescript": "^7.5.2",
    "typescript": "latest",
    "vite": "latest"
  }
}
